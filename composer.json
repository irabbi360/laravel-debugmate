{
  "name": "irabbi360/laravel-debugmate",
  "description": "Error tracking, log viewing, and performance monitoring SDK for Laravel",
  "type": "library",
  "license": "MIT",
  "authors": [
    {
      "name": "DebugMate Team",
      "email": "team@debugmate.app"
    }
  ],
  "require": {
    "php": "^8.2",
    "illuminate/support": "^10.0 || ^11.0 || ^12.0 || ^13.0",
    "illuminate/queue": "^10.0 || ^11.0 || ^12.0 || ^13.0",
    "guzzlehttp/guzzle": "^7.0"
  },
  "require-dev": {
    "phpunit/phpunit": "^10.0",
    "orchestra/testbench": "^8.0 || ^9.0 || ^10.0"
  },
  "autoload": {
    "psr-4": {
      "Irabbi360\\LaravelDebugMate\\": "src/",
      "Irabbi360\\LaravelDebugMate\\Tests\\": "tests/"
    }
  },
  "extra": {
    "laravel": {
      "providers": [
        "Irabbi360\\LaravelDebugMate\\DebugMateServiceProvider"
      ],
      "aliases": {
        "DebugMate": "Irabbi360\\LaravelDebugMate\\Facades\\DebugMate"
      }
    }
  }
}

